# Database (Prisma/PostgreSQL — Neon). Neon's Vercel integration sets both of
# these automatically in production. For local dev, paste the same Neon strings.
# DATABASE_URL = pooled (runtime); DATABASE_URL_UNPOOLED = direct (migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# NextAuth v5 (Auth.js). AUTH_SECRET is what v5 reads; generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Admin account created by `npm run db:seed` (password never hardcoded in the repo).
ADMIN_EMAIL="stupulbio@outlook.com"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Resend — sends order & contact notification emails to the shop.
# Get an API key at https://resend.com (free tier: 3000 emails/month).
# MAIL_FROM must be on a Resend-verified domain; the shared onboarding@resend.dev
# sender works for testing but only delivers to the Resend account's own email.
# MAIL_TO is where order/contact notifications are received.
RESEND_API_KEY="re_replace_with_your_resend_api_key"
MAIL_FROM="Stupul Bio <onboarding@resend.dev>"
MAIL_TO="stupulbio@outlook.com"

# Fan Courier API (shipping tariff at checkout). Leave empty to show
# "se calculează la livrare"; fill all three to enable live estimates.
# USERNAME/PASSWORD = SelfAWB login; CLIENT_ID = SelfAWB branch client id.
FAN_COURIER_USERNAME=""
FAN_COURIER_PASSWORD=""
FAN_COURIER_CLIENT_ID=""
FAN_COURIER_SERVICE="Standard"

# Netopia Payments (card). Empty = card disabled (ramburs still works).
# NETOPIA_LIVE=false uses the sandbox. NETOPIA_PUBLIC_KEY = Netopia's PEM public
# key used to verify the IPN signature.
NETOPIA_API_KEY=""
NETOPIA_POS_SIGNATURE=""
NETOPIA_PUBLIC_KEY=""
NETOPIA_LIVE="false"
