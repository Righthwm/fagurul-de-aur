// Prisma schema — PostgreSQL (Neon) for both local dev and production.
//
// DATABASE_URL          = pooled connection (used at runtime / serverless).
// DATABASE_URL_UNPOOLED = direct connection (used for migrations).
// Neon's Vercel integration sets both automatically. For local dev, copy the
// same connection strings into .env / .env.local.
// `role` and `status` are stored as plain strings (could become Prisma enums).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String      @id @default(cuid())
  email     String      @unique
  name      String
  password  String
  role      String      @default("CLIENT") // "CLIENT" | "ADMIN" (SQLite has no enums)
  createdAt DateTime    @default(now())
  orders    Order[]
  visits    PageVisit[]
}

model PageVisit {
  id         String   @id @default(cuid())
  path       String
  method     String
  ip         String?
  userAgent  String?
  statusCode Int?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Order {
  id                 String   @id @default(cuid())
  orderNumber        String   @unique
  userId             String?
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerFirstName  String
  customerLastName   String
  customerEmail      String
  customerPhone      String
  shippingCounty     String
  shippingCity       String
  shippingAddress    String
  shippingPostalCode String
  paymentMethod      String
  // "n/a" (ramburs) | "pending" | "paid" | "failed" — online payment state.
  paymentStatus      String   @default("n/a")
  // Netopia transaction id (ntpID), set once a card payment is initiated.
  paymentId          String?
  notes              String?
  items              String   // JSON-encoded OrderItem[] (SQLite has no JSON type)
  subtotal           Int
  shipping           Int
  total              Int
  status             String   @default("noua")
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
